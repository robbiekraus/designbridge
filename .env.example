# Designbridge — Environment Variables
# Copy this file to .env and fill in your values

# ── KI-Provider (für Bild-Import & "Mit KI vertiefen"; URL/Repo/Export laufen ohne) ──
# Es reicht EINER der beiden Keys. Ohne beide: DEMO_FALLBACK=1 nutzen.

# Option A: Google Gemini — GRATIS-Kontingent, kein Guthaben nötig.
# Key holen: https://aistudio.google.com (Google-Login, keine Kreditkarte)
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-flash-latest   # optional, Default (Alias aufs aktuelle Flash)

# Option B: Anthropic Claude — pay-per-use, braucht Guthaben.
# Key + Guthaben: https://console.anthropic.com (getrennt vom claude.ai-Abo!)
# ANTHROPIC_API_KEY=sk-ant-...

# Provider erzwingen, falls beide Keys gesetzt sind (Default: anthropic)
# AI_PROVIDER=gemini

# ── Server ──
# Server-Port (lokal Default 3047; Railway/Hoster injizieren PORT automatisch)
PORT=3047

# Produktion: aktiviert das Ausliefern von web/dist + SPA-Fallback.
# Railway setzt das i. d. R. automatisch. Lokal NICHT setzen (sonst serviert
# Express statt Vite). Der "npm start"-Befehl setzt es selbst.
# NODE_ENV=production

# CORS-Origin (Default: http://localhost:5173). In Produktion läuft das Web
# same-origin, daher normalerweise nicht nötig.
# CORS_ORIGIN=https://deine-domain.example

# Demo-Fallback: 1 = Bild-Scan & Interpretation liefern Demo-Daten statt
# echtem KI-Call. Praktisch zum Vorführen ganz ohne Key. Default aus.
# DEMO_FALLBACK=1
