# Designbridge — Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key — nur für Bild-Import (Auto-Scan) & "Mit KI vertiefen" nötig.
# URL-Import, Repo-Import und Figma-Export laufen OHNE Key.
# Key + Guthaben: https://console.anthropic.com  (getrennt vom claude.ai-Abo!)
ANTHROPIC_API_KEY=sk-ant-...

# Server-Port (lokal Default 3047; Railway/Hoster injizieren PORT automatisch)
PORT=3047

# Produktion: aktiviert das Ausliefern von web/dist + SPA-Fallback.
# Railway setzt das i. d. R. automatisch. Lokal NICHT setzen (sonst serviert
# Express statt Vite). Der "npm start"-Befehl setzt es selbst.
# NODE_ENV=production

# CORS-Origin (Default: http://localhost:5173). In Produktion läuft das Web
# same-origin, daher normalerweise nicht nötig. Nur setzen, wenn Frontend und
# API auf getrennten Domains liegen.
# CORS_ORIGIN=https://deine-domain.example

# Demo-Fallback: 1 = Bild-Scan liefert Demo-Daten statt echtem API-Call.
# Praktisch zum Vorführen ohne API-Guthaben. Default aus.
# DEMO_FALLBACK=1
