[
  {
    "name": "Avatar",
    "html": "<div style=\"display:flex;align-items:center;gap:8px\"><div style=\"width:36px;height:36px;background:#4263EB;color:#ffffff;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\">RK</div><div style=\"width:36px;height:36px;background:#EDF2FF;color:#4263EB;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\">AM</div><div style=\"width:36px;height:36px;background:#5C7CFA;color:#ffffff;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\">TS</div><div style=\"width:36px;height:36px;background:#F1F3F5;color:#868E96;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\">+3</div></div>",
    "jsx": "export function Avatar({ initials = \"RK\", className = \"\" }) {\n  return (\n    <div className={`h-9 w-9 rounded-full bg-[#4263EB] text-white flex items-center justify-center text-sm font-medium ${className}`}>\n      {initials}\n    </div>\n  );\n}\n"
  },
  {
    "name": "Status Dot",
    "html": "<div style=\"display:flex;align-items:center;gap:16px;font-size:13px;color:#495057\"><div style=\"display:flex;align-items:center;gap:6px\"><div style=\"width:8px;height:8px;background:#51CF66;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\"></div><span>Aktiv (12)</span></div><div style=\"display:flex;align-items:center;gap:6px\"><div style=\"width:8px;height:8px;background:#FCC419;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\"></div><span>Wartend (4)</span></div><div style=\"display:flex;align-items:center;gap:6px\"><div style=\"width:8px;height:8px;background:#FF6B6B;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\"></div><span>Fehler (1)</span></div></div>",
    "jsx": "export function StatusDot({ color = \"#51CF66\", label = \"Aktiv\" }) {\n  return (\n    <span className=\"flex items-center gap-1.5 text-sm text-[#495057]\">\n      <span className=\"h-2 w-2 rounded-full\" style={{ backgroundColor: color }} />\n      {label}\n    </span>\n  );\n}\n"
  },
  {
    "name": "Sidebar Navigation",
    "html": "<nav style=\"display:flex;flex-direction:column;gap:4px;width:224px;padding:12px;background:#ffffff;border:1px solid #E9ECEF;border-top-left-radius:8px;border-top-right-radius:8px;border-bottom-right-radius:8px;border-bottom-left-radius:8px\"><div style=\"display:flex;align-items:center;justify-content:space-between;padding-top:8px;padding-right:12px;padding-bottom:8px;padding-left:12px;background:#EDF2FF;border-top-left-radius:6px;border-top-right-radius:6px;border-bottom-right-radius:6px;border-bottom-left-radius:6px;font-size:14px;font-weight:600;color:#4263EB\"><span>Dashboard</span></div><div style=\"display:flex;align-items:center;justify-content:space-between;padding-top:8px;padding-right:12px;padding-bottom:8px;padding-left:12px;font-size:14px;color:#495057\"><span>Berichte</span></div><div style=\"display:flex;align-items:center;justify-content:space-between;padding-top:8px;padding-right:12px;padding-bottom:8px;padding-left:12px;font-size:14px;color:#495057\"><span>Ereignisse</span><span style=\"display:flex;align-items:center;justify-content:center;min-width:20px;height:20px;padding-left:6px;padding-right:6px;background:#FF6B6B;color:#ffffff;font-size:11px;font-weight:600;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\">3</span></div><div style=\"display:flex;align-items:center;justify-content:space-between;padding-top:8px;padding-right:12px;padding-bottom:8px;padding-left:12px;font-size:14px;color:#495057\"><span>Einstellungen</span></div></nav>",
    "jsx": "export function SidebarNavigation({ items = [\"Dashboard\", \"Berichte\", \"Ereignisse\", \"Einstellungen\"], active = 0 }) {\n  return (\n    <nav className=\"w-56 rounded-lg border border-[#E9ECEF] bg-white p-3 space-y-1\">\n      {items.map((label, i) => (\n        <div key={label} className={`rounded-md px-3 py-2 text-sm ${i === active ? \"bg-[#EDF2FF] font-medium text-[#4263EB]\" : \"text-[#495057] hover:bg-[#F8F9FA]\"}`}>\n          {label}\n        </div>\n      ))}\n    </nav>\n  );\n}\n"
  },
  {
    "name": "Donut Chart",
    "html": "<div style=\"display:flex;flex-direction:column;gap:12px;padding:16px;background:#ffffff;border:1px solid #E9ECEF;border-top-left-radius:12px;border-top-right-radius:12px;border-bottom-right-radius:12px;border-bottom-left-radius:12px;width:224px\"><div style=\"font-size:14px;font-weight:600;color:#212529\">Kategorien</div><div style=\"display:flex;justify-content:center\"><svg viewBox=\"0 0 42 42\" style=\"width:112px;height:112px\"><circle cx=\"21\" cy=\"21\" r=\"15.9\" fill=\"none\" stroke=\"#E9ECEF\" stroke-width=\"6\"></circle><circle cx=\"21\" cy=\"21\" r=\"15.9\" fill=\"none\" stroke=\"#4263EB\" stroke-width=\"6\" stroke-dasharray=\"55 45\" stroke-dashoffset=\"25\"></circle><circle cx=\"21\" cy=\"21\" r=\"15.9\" fill=\"none\" stroke=\"#51CF66\" stroke-width=\"6\" stroke-dasharray=\"25 75\" stroke-dashoffset=\"70\"></circle><text x=\"21\" y=\"19\" text-anchor=\"middle\" font-size=\"7\" font-weight=\"700\" fill=\"#212529\">248</text><text x=\"21\" y=\"25\" text-anchor=\"middle\" font-size=\"3.6\" fill=\"#868E96\">Gesamt</text></svg></div><div style=\"display:flex;flex-direction:column;gap:6px\"><div style=\"display:flex;align-items:center;gap:8px\"><div style=\"width:10px;height:10px;background:#4263EB;border-top-left-radius:2px;border-top-right-radius:2px;border-bottom-right-radius:2px;border-bottom-left-radius:2px\"></div><div style=\"flex:1;font-size:12px;color:#495057\">Marketing</div><div style=\"font-size:12px;font-weight:600;color:#212529\">55%</div></div><div style=\"display:flex;align-items:center;gap:8px\"><div style=\"width:10px;height:10px;background:#51CF66;border-top-left-radius:2px;border-top-right-radius:2px;border-bottom-right-radius:2px;border-bottom-left-radius:2px\"></div><div style=\"flex:1;font-size:12px;color:#495057\">Vertrieb</div><div style=\"font-size:12px;font-weight:600;color:#212529\">25%</div></div><div style=\"display:flex;align-items:center;gap:8px\"><div style=\"width:10px;height:10px;background:#E9ECEF;border-top-left-radius:2px;border-top-right-radius:2px;border-bottom-right-radius:2px;border-bottom-left-radius:2px\"></div><div style=\"flex:1;font-size:12px;color:#495057\">Sonstiges</div><div style=\"font-size:12px;font-weight:600;color:#212529\">20%</div></div></div></div>",
    "jsx": "export function DonutChart({ title = \"Kategorien\" }) {\n  return (\n    <div className=\"rounded-lg border border-[#E9ECEF] bg-white p-4 w-56\">\n      <div className=\"text-sm font-medium text-[#212529] mb-3\">{title}</div>\n      <svg viewBox=\"0 0 42 42\" className=\"h-28 w-28 mx-auto\">\n        <circle cx=\"21\" cy=\"21\" r=\"15.9\" fill=\"none\" stroke=\"#E9ECEF\" strokeWidth=\"6\" />\n        <circle cx=\"21\" cy=\"21\" r=\"15.9\" fill=\"none\" stroke=\"#4263EB\" strokeWidth=\"6\" strokeDasharray=\"55 45\" strokeDashoffset=\"25\" />\n        <circle cx=\"21\" cy=\"21\" r=\"15.9\" fill=\"none\" stroke=\"#51CF66\" strokeWidth=\"6\" strokeDasharray=\"25 75\" strokeDashoffset=\"70\" />\n      </svg>\n    </div>\n  );\n}\n"
  },
  {
    "name": "Bar Chart",
    "html": "<div style=\"display:flex;flex-direction:column;gap:12px;padding:16px;background:#ffffff;border:1px solid #E9ECEF;border-top-left-radius:12px;border-top-right-radius:12px;border-bottom-right-radius:12px;border-bottom-left-radius:12px;width:320px\"><div style=\"display:flex;align-items:center;justify-content:space-between\"><div style=\"font-size:14px;font-weight:600;color:#212529\">Umsatz je Monat</div><div style=\"font-size:12px;font-weight:600;color:#2B8A3E\">+18% ggü. Vorquartal</div></div><div style=\"display:flex;align-items:flex-end;gap:8px;height:150px\"><div style=\"display:flex;flex-direction:column;align-items:center;gap:4px\"><div style=\"font-size:11px;font-weight:600;color:#495057\">12k</div><div style=\"width:36px;height:48px;background:#4263EB;border-top-left-radius:4px;border-top-right-radius:4px\"></div><div style=\"font-size:10px;color:#868E96\">Jan</div></div><div style=\"display:flex;flex-direction:column;align-items:center;gap:4px\"><div style=\"font-size:11px;font-weight:600;color:#495057\">19k</div><div style=\"width:36px;height:78px;background:#4263EB;border-top-left-radius:4px;border-top-right-radius:4px\"></div><div style=\"font-size:10px;color:#868E96\">Feb</div></div><div style=\"display:flex;flex-direction:column;align-items:center;gap:4px\"><div style=\"font-size:11px;font-weight:600;color:#495057\">15k</div><div style=\"width:36px;height:60px;background:#4263EB;border-top-left-radius:4px;border-top-right-radius:4px\"></div><div style=\"font-size:10px;color:#868E96\">Mär</div></div><div style=\"display:flex;flex-direction:column;align-items:center;gap:4px\"><div style=\"font-size:11px;font-weight:600;color:#495057\">26k</div><div style=\"width:36px;height:104px;background:#4263EB;border-top-left-radius:4px;border-top-right-radius:4px\"></div><div style=\"font-size:10px;color:#868E96\">Apr</div></div><div style=\"display:flex;flex-direction:column;align-items:center;gap:4px\"><div style=\"font-size:11px;font-weight:600;color:#495057\">30k</div><div style=\"width:36px;height:120px;background:#5C7CFA;border-top-left-radius:4px;border-top-right-radius:4px\"></div><div style=\"font-size:10px;color:#868E96\">Mai</div></div></div><div style=\"display:flex;align-items:center;gap:8px\"><div style=\"width:10px;height:10px;background:#4263EB;border-top-left-radius:2px;border-top-right-radius:2px;border-bottom-right-radius:2px;border-bottom-left-radius:2px\"></div><div style=\"font-size:11px;color:#868E96\">Umsatz in Tsd. €</div></div></div>",
    "jsx": "export function BarChart({ title = \"Umsatz je Monat\", values = [40, 65, 50, 85, 100] }) {\n  return (\n    <div className=\"rounded-lg border border-[#E9ECEF] bg-white p-4 w-64\">\n      <div className=\"text-sm font-medium text-[#212529] mb-3\">{title}</div>\n      <div className=\"flex items-end gap-2 h-24\">\n        {values.map((v, i) => (\n          <div key={i} className=\"flex-1 rounded-t bg-[#4263EB]\" style={{ height: `${v}%` }} />\n        ))}\n      </div>\n    </div>\n  );\n}\n"
  },
  {
    "name": "Data Table",
    "html": "<div style=\"display:flex;flex-direction:column;background:#ffffff;border:1px solid #E9ECEF;border-top-left-radius:12px;border-top-right-radius:12px;border-bottom-right-radius:12px;border-bottom-left-radius:12px;width:340px\"><div style=\"display:flex;align-items:center;gap:12px;background:#F8F9FA;padding-top:8px;padding-right:12px;padding-bottom:8px;padding-left:12px\"><div style=\"flex:1;font-size:12px;font-weight:600;color:#868E96\">Ereignis</div><div style=\"width:60px;font-size:12px;font-weight:600;color:#868E96\">Status</div><div style=\"width:56px;font-size:12px;font-weight:600;color:#868E96;text-align:right\">Zeit</div></div><div style=\"display:flex;align-items:center;gap:12px;border-top:1px solid #F1F3F5;padding-top:10px;padding-right:12px;padding-bottom:10px;padding-left:12px\"><div style=\"flex:1;font-size:13px;color:#212529\">Deploy v2.1</div><div style=\"width:60px;display:flex\"><span style=\"display:flex;align-items:center;background:#D3F9D8;color:#2B8A3E;font-size:11px;font-weight:600;padding-top:2px;padding-right:6px;padding-bottom:2px;padding-left:6px;border-top-left-radius:4px;border-top-right-radius:4px;border-bottom-right-radius:4px;border-bottom-left-radius:4px\">OK</span></div><div style=\"width:56px;font-size:12px;color:#868E96;text-align:right\">08:14</div></div><div style=\"display:flex;align-items:center;gap:12px;border-top:1px solid #F1F3F5;padding-top:10px;padding-right:12px;padding-bottom:10px;padding-left:12px\"><div style=\"flex:1;font-size:13px;color:#212529\">Import Lauf</div><div style=\"width:60px;display:flex\"><span style=\"display:flex;align-items:center;background:#FFF3BF;color:#E67700;font-size:11px;font-weight:600;padding-top:2px;padding-right:6px;padding-bottom:2px;padding-left:6px;border-top-left-radius:4px;border-top-right-radius:4px;border-bottom-right-radius:4px;border-bottom-left-radius:4px\">Läuft</span></div><div style=\"width:56px;font-size:12px;color:#868E96;text-align:right\">08:32</div></div><div style=\"display:flex;align-items:center;gap:12px;border-top:1px solid #F1F3F5;padding-top:10px;padding-right:12px;padding-bottom:10px;padding-left:12px\"><div style=\"flex:1;font-size:13px;color:#212529\">Nightly Backup</div><div style=\"width:60px;display:flex\"><span style=\"display:flex;align-items:center;background:#FFE3E3;color:#C92A2A;font-size:11px;font-weight:600;padding-top:2px;padding-right:6px;padding-bottom:2px;padding-left:6px;border-top-left-radius:4px;border-top-right-radius:4px;border-bottom-right-radius:4px;border-bottom-left-radius:4px\">Fehler</span></div><div style=\"width:56px;font-size:12px;color:#868E96;text-align:right\">03:00</div></div><div style=\"display:flex;align-items:center;gap:12px;border-top:1px solid #F1F3F5;padding-top:10px;padding-right:12px;padding-bottom:10px;padding-left:12px\"><div style=\"flex:1;font-size:13px;color:#212529\">Health Check</div><div style=\"width:60px;display:flex\"><span style=\"display:flex;align-items:center;background:#F1F3F5;color:#868E96;font-size:11px;font-weight:600;padding-top:2px;padding-right:6px;padding-bottom:2px;padding-left:6px;border-top-left-radius:4px;border-top-right-radius:4px;border-bottom-right-radius:4px;border-bottom-left-radius:4px\">Wartet</span></div><div style=\"width:56px;font-size:12px;color:#868E96;text-align:right\">--:--</div></div></div>",
    "jsx": "export function DataTable({ rows = [[\"Deploy v2.1\", \"OK\"], [\"Import Lauf\", \"Läuft\"]] }) {\n  return (\n    <div className=\"rounded-lg border border-[#E9ECEF] bg-white overflow-hidden\">\n      <table className=\"w-full text-sm\">\n        <thead>\n          <tr className=\"bg-[#F8F9FA] text-left text-[#868E96]\">\n            <th className=\"px-3 py-2 font-medium\">Ereignis</th>\n            <th className=\"px-3 py-2 font-medium\">Status</th>\n          </tr>\n        </thead>\n        <tbody>\n          {rows.map(([name, status]) => (\n            <tr key={name} className=\"border-t border-[#F1F3F5]\">\n              <td className=\"px-3 py-2 text-[#212529]\">{name}</td>\n              <td className=\"px-3 py-2\">{status}</td>\n            </tr>\n          ))}\n        </tbody>\n      </table>\n    </div>\n  );\n}\n"
  },
  {
    "name": "Tooltip",
    "html": "<div style=\"display:flex;flex-direction:column;align-items:center\"><div style=\"background:#1A1B1E;color:#ffffff;font-size:12px;padding-top:6px;padding-right:8px;padding-bottom:6px;padding-left:8px;border-top-left-radius:6px;border-top-right-radius:6px;border-bottom-right-radius:6px;border-bottom-left-radius:6px\">Details anzeigen</div><div style=\"width:8px;height:8px;margin-top:-4px;background:#1A1B1E;transform:rotate(45deg)\"></div></div>",
    "jsx": "export function Tooltip({ label = \"Details anzeigen\" }) {\n  return (\n    <div className=\"inline-flex flex-col items-center\">\n      <div className=\"rounded bg-[#1A1B1E] px-2 py-1 text-xs text-white\">{label}</div>\n      <div className=\"h-2 w-2 -mt-1 rotate-45 bg-[#1A1B1E]\" />\n    </div>\n  );\n}\n"
  },
  {
    "name": "Segmented Control",
    "html": "<div style=\"display:flex;align-items:center;gap:4px;padding:4px;background:#F1F3F5;border-top-left-radius:10px;border-top-right-radius:10px;border-bottom-right-radius:10px;border-bottom-left-radius:10px;width:220px\"><div style=\"flex:1;text-align:center;padding-top:6px;padding-right:12px;padding-bottom:6px;padding-left:12px;background:#ffffff;border-top-left-radius:8px;border-top-right-radius:8px;border-bottom-right-radius:8px;border-bottom-left-radius:8px;font-size:13px;font-weight:600;color:#212529\">Woche</div><div style=\"flex:1;text-align:center;padding-top:6px;padding-right:12px;padding-bottom:6px;padding-left:12px;font-size:13px;color:#868E96\">Monat</div><div style=\"flex:1;text-align:center;padding-top:6px;padding-right:12px;padding-bottom:6px;padding-left:12px;font-size:13px;color:#868E96\">Jahr</div></div>",
    "jsx": "export function SegmentedControl({ options = [\"Woche\", \"Monat\", \"Jahr\"], active = 0 }) {\n  return (\n    <div className=\"inline-flex rounded-lg bg-[#F1F3F5] p-1 text-sm\">\n      {options.map((o, i) => (\n        <div key={o} className={`px-3 py-1 ${i === active ? \"rounded-md bg-white font-medium text-[#212529] shadow-sm\" : \"text-[#868E96]\"}`}>\n          {o}\n        </div>\n      ))}\n    </div>\n  );\n}\n"
  },
  {
    "name": "Category List Item",
    "html": "<div style=\"display:flex;flex-direction:column;gap:10px;padding:12px;background:#ffffff;border:1px solid #E9ECEF;border-top-left-radius:12px;border-top-right-radius:12px;border-bottom-right-radius:12px;border-bottom-left-radius:12px;width:260px\"><div style=\"display:flex;align-items:center;gap:10px\"><div style=\"width:10px;height:10px;background:#4263EB;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\"></div><div style=\"flex:1;font-size:13px;color:#212529\">Marketing</div><div style=\"width:96px;height:6px;background:#F1F3F5;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\"><div style=\"width:40px;height:6px;background:#4263EB;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\"></div></div><div style=\"width:34px;font-size:12px;font-weight:600;color:#212529;text-align:right\">42%</div></div><div style=\"display:flex;align-items:center;gap:10px\"><div style=\"width:10px;height:10px;background:#51CF66;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\"></div><div style=\"flex:1;font-size:13px;color:#212529\">Vertrieb</div><div style=\"width:96px;height:6px;background:#F1F3F5;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\"><div style=\"width:30px;height:6px;background:#51CF66;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\"></div></div><div style=\"width:34px;font-size:12px;font-weight:600;color:#212529;text-align:right\">31%</div></div><div style=\"display:flex;align-items:center;gap:10px\"><div style=\"width:10px;height:10px;background:#FCC419;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\"></div><div style=\"flex:1;font-size:13px;color:#212529\">Support</div><div style=\"width:96px;height:6px;background:#F1F3F5;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\"><div style=\"width:26px;height:6px;background:#FCC419;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\"></div></div><div style=\"width:34px;font-size:12px;font-weight:600;color:#212529;text-align:right\">27%</div></div></div>",
    "jsx": "export function CategoryListItem({ label = \"Marketing\", value = \"42%\", color = \"#4263EB\" }) {\n  return (\n    <div className=\"flex items-center gap-3 rounded-lg border border-[#E9ECEF] bg-white px-3 py-2\">\n      <span className=\"h-2.5 w-2.5 rounded-full\" style={{ backgroundColor: color }} />\n      <span className=\"flex-1 text-sm text-[#212529]\">{label}</span>\n      <span className=\"text-sm font-medium text-[#212529]\">{value}</span>\n    </div>\n  );\n}\n"
  },
  {
    "name": "Dashboard Grid Layout",
    "html": "<div style=\"display:flex;flex-direction:column;gap:12px;width:320px\"><div style=\"display:flex;gap:12px\"><div style=\"flex:1;height:64px;display:flex;flex-direction:column;justify-content:center;gap:2px;padding-top:10px;padding-right:12px;padding-bottom:10px;padding-left:12px;background:#ffffff;border:1px solid #E9ECEF;border-top-left-radius:10px;border-top-right-radius:10px;border-bottom-right-radius:10px;border-bottom-left-radius:10px\"><div style=\"font-size:11px;color:#868E96\">Umsatz</div><div style=\"font-size:16px;font-weight:700;color:#212529\">€48.2k</div></div><div style=\"flex:1;height:64px;display:flex;flex-direction:column;justify-content:center;gap:2px;padding-top:10px;padding-right:12px;padding-bottom:10px;padding-left:12px;background:#ffffff;border:1px solid #E9ECEF;border-top-left-radius:10px;border-top-right-radius:10px;border-bottom-right-radius:10px;border-bottom-left-radius:10px\"><div style=\"font-size:11px;color:#868E96\">Nutzer</div><div style=\"font-size:16px;font-weight:700;color:#212529\">1.204</div></div><div style=\"flex:1;height:64px;display:flex;flex-direction:column;justify-content:center;gap:2px;padding-top:10px;padding-right:12px;padding-bottom:10px;padding-left:12px;background:#ffffff;border:1px solid #E9ECEF;border-top-left-radius:10px;border-top-right-radius:10px;border-bottom-right-radius:10px;border-bottom-left-radius:10px\"><div style=\"font-size:11px;color:#868E96\">Tickets</div><div style=\"font-size:16px;font-weight:700;color:#212529\">12</div></div></div><div style=\"display:flex;gap:12px\"><div style=\"width:196px;height:96px;display:flex;flex-direction:column;justify-content:space-between;padding-top:12px;padding-right:12px;padding-bottom:12px;padding-left:12px;background:#ffffff;border:1px solid #E9ECEF;border-top-left-radius:10px;border-top-right-radius:10px;border-bottom-right-radius:10px;border-bottom-left-radius:10px\"><div style=\"font-size:11px;color:#868E96\">Wochenverlauf</div><div style=\"display:flex;align-items:flex-end;gap:6px;height:40px\"><div style=\"width:18px;height:18px;background:#CED4DA;border-top-left-radius:3px;border-top-right-radius:3px\"></div><div style=\"width:18px;height:26px;background:#CED4DA;border-top-left-radius:3px;border-top-right-radius:3px\"></div><div style=\"width:18px;height:22px;background:#CED4DA;border-top-left-radius:3px;border-top-right-radius:3px\"></div><div style=\"width:18px;height:36px;background:#4263EB;border-top-left-radius:3px;border-top-right-radius:3px\"></div><div style=\"width:18px;height:32px;background:#CED4DA;border-top-left-radius:3px;border-top-right-radius:3px\"></div></div></div><div style=\"flex:1;height:96px;display:flex;flex-direction:column;justify-content:space-between;padding-top:12px;padding-right:12px;padding-bottom:12px;padding-left:12px;background:#ffffff;border:1px solid #E9ECEF;border-top-left-radius:10px;border-top-right-radius:10px;border-bottom-right-radius:10px;border-bottom-left-radius:10px\"><div style=\"font-size:11px;color:#868E96\">Ziel</div><div style=\"font-size:20px;font-weight:700;color:#212529\">76%</div></div></div></div>",
    "jsx": "export function DashboardGridLayout({ children }) {\n  return <div className=\"grid grid-cols-3 gap-3\">{children}</div>;\n}\n"
  },
  {
    "name": "Metrics Overview",
    "html": "<div style=\"display:flex;gap:12px\"><div style=\"width:144px;display:flex;flex-direction:column;gap:4px;padding:16px;background:#ffffff;border:1px solid #E9ECEF;border-top-left-radius:12px;border-top-right-radius:12px;border-bottom-right-radius:12px;border-bottom-left-radius:12px\"><div style=\"font-size:12px;color:#868E96\">Umsatz</div><div style=\"font-size:20px;font-weight:600;color:#1A1B1E\">€48.2k</div><div style=\"display:flex;align-items:center;gap:4px;font-size:12px;color:#2B8A3E\"><span>▲</span><span>+12%</span></div></div><div style=\"width:144px;display:flex;flex-direction:column;gap:4px;padding:16px;background:#ffffff;border:1px solid #E9ECEF;border-top-left-radius:12px;border-top-right-radius:12px;border-bottom-right-radius:12px;border-bottom-left-radius:12px\"><div style=\"font-size:12px;color:#868E96\">Nutzer</div><div style=\"font-size:20px;font-weight:600;color:#1A1B1E\">1.204</div><div style=\"display:flex;align-items:center;gap:4px;font-size:12px;color:#C92A2A\"><span>▼</span><span>-3%</span></div></div><div style=\"width:144px;display:flex;flex-direction:column;gap:4px;padding:16px;background:#ffffff;border:1px solid #E9ECEF;border-top-left-radius:12px;border-top-right-radius:12px;border-bottom-right-radius:12px;border-bottom-left-radius:12px\"><div style=\"font-size:12px;color:#868E96\">Konversion</div><div style=\"font-size:20px;font-weight:600;color:#1A1B1E\">3.8%</div><div style=\"display:flex;align-items:center;gap:4px;font-size:12px;color:#2B8A3E\"><span>▲</span><span>+0.4pp</span></div></div></div>",
    "jsx": "export function MetricsOverview({ metrics = [{ label: \"Umsatz\", value: \"€48.2k\", delta: \"+12%\" }] }) {\n  return (\n    <div className=\"flex gap-3\">\n      {metrics.map((m) => (\n        <div key={m.label} className=\"rounded-lg border border-[#E9ECEF] bg-white p-4 w-36\">\n          <div className=\"text-xs text-[#868E96]\">{m.label}</div>\n          <div className=\"text-xl font-semibold text-[#1A1B1E]\">{m.value}</div>\n          <div className=\"text-xs text-[#2B8A3E]\">{m.delta}</div>\n        </div>\n      ))}\n    </div>\n  );\n}\n"
  },
  {
    "name": "Sidebar + Content Shell",
    "html": "<div style=\"display:flex;gap:12px;width:340px\"><div style=\"width:96px;height:140px;display:flex;flex-direction:column;gap:4px;padding-top:12px;padding-right:8px;padding-bottom:12px;padding-left:8px;background:#F8F9FA;border:1px solid #E9ECEF;border-top-left-radius:10px;border-top-right-radius:10px;border-bottom-right-radius:10px;border-bottom-left-radius:10px\"><div style=\"padding-top:6px;padding-right:8px;padding-bottom:6px;padding-left:8px;background:#EDF2FF;color:#4263EB;font-size:11px;font-weight:600;border-top-left-radius:6px;border-top-right-radius:6px;border-bottom-right-radius:6px;border-bottom-left-radius:6px\">Übersicht</div><div style=\"padding-top:6px;padding-right:8px;padding-bottom:6px;padding-left:8px;color:#868E96;font-size:11px\">Berichte</div><div style=\"padding-top:6px;padding-right:8px;padding-bottom:6px;padding-left:8px;color:#868E96;font-size:11px\">Team</div></div><div style=\"flex:1;display:flex;flex-direction:column;gap:8px\"><div style=\"height:32px;display:flex;align-items:center;justify-content:space-between;padding-left:12px;padding-right:12px;background:#ffffff;border:1px solid #E9ECEF;border-top-left-radius:8px;border-top-right-radius:8px;border-bottom-right-radius:8px;border-bottom-left-radius:8px\"><div style=\"font-size:13px;font-weight:600;color:#212529\">Projektübersicht</div><div style=\"font-size:11px;color:#868E96\">Heute</div></div><div style=\"height:96px;display:flex;flex-direction:column;gap:8px;padding-top:12px;padding-right:12px;padding-bottom:12px;padding-left:12px;background:#ffffff;border:1px solid #E9ECEF;border-top-left-radius:8px;border-top-right-radius:8px;border-bottom-right-radius:8px;border-bottom-left-radius:8px\"><div style=\"font-size:12px;color:#868E96\">Fortschritt</div><div style=\"font-size:18px;font-weight:700;color:#212529\">68%</div><div style=\"width:280px;height:6px;background:#F1F3F5;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\"><div style=\"width:190px;height:6px;background:#4263EB;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\"></div></div></div></div></div>",
    "jsx": "export function SidebarContentShell({ sidebar, children }) {\n  return (\n    <div className=\"flex gap-3\">\n      <div className=\"w-56 shrink-0\">{sidebar}</div>\n      <div className=\"flex-1 space-y-3\">{children}</div>\n    </div>\n  );\n}\n"
  },
  {
    "name": "Stat Card",
    "html": "<div style=\"display:flex;flex-direction:column;gap:4px;padding:16px;background:#ffffff;border:1px solid #e5e7eb;border-top-left-radius:12px;border-top-right-radius:12px;border-bottom-right-radius:12px;border-bottom-left-radius:12px;width:224px\"><div style=\"font-size:12px;color:#6b7280\">Total Sales</div><div style=\"font-size:24px;font-weight:600;color:#111827\">$12,480</div><div style=\"display:flex;align-items:center;gap:4px;font-size:12px;color:#16a34a\"><span>▲</span><span>+8.2% vs last week</span></div></div>",
    "jsx": "export function StatCard(){return (<div className=\"rounded-xl border bg-white p-4 w-56\"><p className=\"text-xs text-muted-foreground\">Total Sales</p><p className=\"mt-1 text-2xl font-semibold\">$12,480</p><p className=\"mt-1 text-xs text-green-600\">+8.2% vs last week</p></div>);}"
  },
  {
    "name": "Line Chart Card",
    "html": "<div style=\"display:flex;flex-direction:column;gap:8px;padding:16px;background:#ffffff;border:1px solid #e5e7eb;border-top-left-radius:12px;border-top-right-radius:12px;border-bottom-right-radius:12px;border-bottom-left-radius:12px;width:320px\"><div style=\"display:flex;align-items:center;justify-content:space-between\"><div style=\"font-size:14px;font-weight:600;color:#111827\">Income Details</div><div style=\"font-size:12px;font-weight:600;color:#16a34a\">$28.4k</div></div><svg viewBox=\"0 0 300 120\" style=\"width:300px;height:120px\"><line x1=\"0\" y1=\"30\" x2=\"300\" y2=\"30\" stroke=\"#e5e7eb\" stroke-width=\"1\"></line><line x1=\"0\" y1=\"60\" x2=\"300\" y2=\"60\" stroke=\"#e5e7eb\" stroke-width=\"1\"></line><line x1=\"0\" y1=\"90\" x2=\"300\" y2=\"90\" stroke=\"#e5e7eb\" stroke-width=\"1\"></line><polyline fill=\"none\" stroke=\"#4263EB\" stroke-width=\"3\" points=\"0,90 50,70 100,80 150,40 200,55 250,20 300,35\"></polyline><circle cx=\"250\" cy=\"20\" r=\"4\" fill=\"#4263EB\"></circle><text x=\"250\" y=\"12\" text-anchor=\"middle\" font-size=\"10\" font-weight=\"700\" fill=\"#111827\">$28.4k</text></svg><div style=\"display:flex;align-items:center;justify-content:space-between;font-size:11px;color:#9ca3af\"><span>Jan</span><span>Feb</span><span>Mär</span><span>Apr</span><span>Mai</span><span>Jun</span><span>Jul</span></div><div style=\"display:flex;align-items:center;gap:6px\"><div style=\"width:10px;height:10px;background:#4263EB;border-top-left-radius:9999px;border-top-right-radius:9999px;border-bottom-right-radius:9999px;border-bottom-left-radius:9999px\"></div><div style=\"font-size:11px;color:#9ca3af\">Einkommen (2026)</div></div></div>",
    "jsx": "export function LineChartCard(){return (<div className=\"rounded-xl border bg-white p-4 w-80\"><p className=\"text-sm font-medium\">Income Details</p><svg viewBox=\"0 0 300 120\" className=\"mt-2 w-full h-28\"><polyline fill=\"none\" stroke=\"#4263EB\" strokeWidth=\"3\" points=\"0,90 50,70 100,80 150,40 200,55 250,20 300,35\"/></svg></div>);}"
  }
