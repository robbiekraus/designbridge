{
  "name": "designbridge-plugin",
  "version": "1.0.0",
  "description": "DesignBridge Figma Plugin — Sprint 1",
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "codegen": "node dist/codegen.js",
    "export": "node scripts/sync-exports.js",
    "test:writer": "node scripts/build-tests.js && node --test dist/tests/*.test.js"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.90.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "uuid": "^11.1.1"
  }
}
