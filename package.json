{
  "name": "designbridge",
  "version": "0.1.0",
  "description": "Sync design systems between Figma and code — automatically.",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run web\"",
    "server": "node --watch server/index.js",
    "web": "cd web && npm run dev",
    "install:all": "npm install && cd web && npm install",
    "test:server": "node --test 'server/lib/*.test.js'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "node-html-parser": "^8.0.4",
    "postcss": "^8.4.38"
  }
}
